rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if file is an allowed image type
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }

    // Check if file is a video
    function isVideo() {
      return request.resource.contentType.matches('video/.*');
    }

    // Check if file is a PDF
    function isPdf() {
      return request.resource.contentType == 'application/pdf';
    }

    // Check if file is an allowed media type
    function isAllowedMedia() {
      return isImage() || isVideo() || isPdf();
    }

    // Max file size: 50MB for videos, 10MB for images/PDFs
    function isWithinSizeLimit() {
      return (isVideo() && request.resource.size < 50 * 1024 * 1024) ||
             (!isVideo() && request.resource.size < 10 * 1024 * 1024);
    }

    // ============================================
    // POST MEDIA
    // Path: /media/posts/{postId}/{fileName}
    // ============================================
    match /media/posts/{postId}/{fileName} {
      // Public read for all post media
      // Note: For production, consider checking post.status == 'verified' via Cloud Functions
      allow read: if true;

      // Authenticated users can upload to their posts
      // Note: Ideally verify postId ownership, but requires custom claims or Cloud Function
      allow write: if isAuthenticated() && isAllowedMedia() && isWithinSizeLimit();

      // Delete allowed for authenticated users (ownership checked via Cloud Function)
      allow delete: if isAuthenticated();
    }

    // ============================================
    // REQUEST MEDIA
    // Path: /media/requests/{requestId}/{fileName}
    // ============================================
    match /media/requests/{requestId}/{fileName} {
      // Public read for all request media
      allow read: if true;

      // Authenticated users can upload
      allow write: if isAuthenticated() && isAllowedMedia() && isWithinSizeLimit();

      // Delete allowed for authenticated users
      allow delete: if isAuthenticated();
    }

    // ============================================
    // ORGANIZATION MEDIA (logos, etc.)
    // Path: /media/orgs/{orgId}/{type}/{fileName}
    // ============================================
    match /media/orgs/{orgId}/{type}/{fileName} {
      // Public read for org media
      allow read: if true;

      // Authenticated users can upload (ownership should be verified via Cloud Function)
      allow write: if isAuthenticated() && isImage() && request.resource.size < 5 * 1024 * 1024;

      // Delete allowed for authenticated users
      allow delete: if isAuthenticated();
    }

    // ============================================
    // USER AVATARS
    // Path: /media/users/{userId}/avatar/{fileName}
    // ============================================
    match /media/users/{userId}/avatar/{fileName} {
      // Public read
      allow read: if true;

      // Only the user can upload their avatar
      allow write: if isAuthenticated() &&
                      request.auth.uid == userId &&
                      isImage() &&
                      request.resource.size < 5 * 1024 * 1024;

      // User can delete their avatar
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // ============================================
    // THUMBNAILS (generated by Cloud Functions)
    // Path: /thumbnails/{type}/{id}/{fileName}
    // ============================================
    match /thumbnails/{type}/{id}/{fileName} {
      // Public read
      allow read: if true;

      // No client writes - generated by Cloud Functions only
      allow write: if false;
    }

    // ============================================
    // DEFAULT: Deny all other paths
    // ============================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
